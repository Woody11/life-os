PORT=3030
DB_PATH=/data/lifeos.db
WEALTHCANVAS_URL=http://192.168.86.212:3000
LEGO_STUDIO_URL=http://192.168.86.211:8080
OBSIDIAN_URL=https://192.168.86.202:27124
OBSIDIAN_TOKEN=your_obsidian_token_here
# Base URL of the OpenClaw gateway (no trailing slash, no /hooks suffix —
# dispatchAgent.js appends /hooks/wake itself). Use the Mac mini's stable
# mDNS hostname rather than its DHCP-assigned LAN IP, which can drift.
OPENCLAW_GATEWAY_URL=http://Adrians-Mac-mini.local:18789
# Must match openclaw.json's hooks.token
OPENCLAW_HOOK_TOKEN=your_openclaw_hook_token_here
# google-sync/action-api.js on the Mac mini — Gmail archive/read/draft actions.
# Token must match tokens/action-api-secret.txt in the OpenClaw workspace.
GOOGLE_ACTIONS_URL=http://Adrians-Mac-mini.local:3940
GOOGLE_ACTIONS_TOKEN=your_action_api_secret_here
