{
  "name": "life-os",
  "version": "2.0.0",
  "description": "Life OS v2 — single-container React + Express + SQLite app",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "client:install": "npm --prefix client install"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "helmet": "^8.3.0",
    "multer": "^2.2.0"
  }
}
